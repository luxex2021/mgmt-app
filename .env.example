# ============================================================
#  .env  ― ローカル開発用の環境変数ファイル
#
#  【使い方】
#  1. このファイルを .env という名前でコピーする
#     cp .env.example .env
#  2. Supabase の値を書き換える
#  3. .env は Git にコミットしない（.gitignore に追加すること）
#
#  【Renderへのデプロイ時】
#  .env は使わず、Render ダッシュボードの
#  「Environment」タブに同じ変数を設定すること
# ============================================================

# ── Supabase接続情報（必須） ──────────────────────────────
# Supabase ダッシュボード → Project Settings → API から取得

# プロジェクトのURL
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# anon（公開）キー ※ service_role キーは使わない
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxxxxxxxx

# ── サーバーポート ────────────────────────────────────────
# ローカル開発用（Renderは自動で設定するので変更不要）
PORT=3000
